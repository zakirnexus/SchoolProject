@model IEnumerable<SchoolProject.Models.StudyAbroad.IntlInstitute>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Study Abroad – Institutes";
}

<h1 class="mb-3">Study Abroad – Institutes</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="mb-3">
    <a class="btn btn-primary" asp-action="Create" asp-controller="AdminStudyAbroadInstitute">
        + Add Institute
    </a>
</div>

<table class="table table-striped table-bordered table-sm">
    <thead>
        <tr>
            <th>Institute</th>
            <th>Country</th>
            <th>City</th>
            <th>University</th>
            <th>Status</th>
            <th style="width: 160px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var i in Model)
        {
            <tr>
                <td>@i.InstituteName</td>
                <td>@i.Country?.CountryName</td>
                <td>@i.City?.CityName</td>
                <td>@i.UniversityName</td>
                <td>@i.Status</td>
                <td>
                    <a class="btn btn-sm btn-secondary"
                    asp-action="Edit"
                    asp-controller="AdminStudyAbroadInstitute"
                    asp-route-id="@i.InstituteId">
                        Edit
                    </a>

                    <a class="btn btn-sm btn-info"
                    asp-controller="AdminStudyAbroadCourse"
                    asp-action="InstituteCourses"
                    asp-route-instituteId="@i.InstituteId">
                        Courses
                    </a>

                    <form asp-action="Delete"
                        asp-controller="AdminStudyAbroadInstitute"
                        asp-route-id="@i.InstituteId"
                        method="post"
                        style="display:inline;"
                        onsubmit="return confirm('Mark this institute as inactive?');">
                        <button type="submit" class="btn btn-sm btn-danger">
                            Delete
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>