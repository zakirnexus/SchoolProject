@model IEnumerable<SchoolProject.Models.StudyAbroad.CourseIntl>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Study Abroad – Courses";
}

<h1 class="mb-3">Study Abroad – Courses</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="mb-3">
    <a class="btn btn-primary"
       asp-action="Create"
       asp-controller="AdminStudyAbroadCourse">
        + Add Course
    </a>
</div>

<table class="table table-striped table-bordered table-sm">
    <thead>
        <tr>
            <th>Course</th>
            <th>Category</th>
            <th>Level</th>
            <th>Degree Type</th>
            <th>Active</th>
            <th style="width: 180px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.CourseName</td>
                <td>@c.Category?.Name</td>
                <td>@c.Level?.LevelName</td>
                <td>@c.DegreeType</td>
                <td>@(c.IsActive ? "Yes" : "No")</td>
                <td>
                    <a class="btn btn-sm btn-secondary"
                       asp-action="Edit"
                       asp-controller="AdminStudyAbroadCourse"
                       asp-route-id="@c.CourseId">
                        Edit
                    </a>

                    <form asp-action="Delete"
                          asp-controller="AdminStudyAbroadCourse"
                          asp-route-id="@c.CourseId"
                          method="post"
                          style="display:inline;"
                          onsubmit="return confirm('Deactivate this course?');">
                        <button type="submit" class="btn btn-sm btn-danger">
                            Delete
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>