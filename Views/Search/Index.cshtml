@model List<SchoolProject.Models.Search.SearchResultViewModel>

@{
    ViewData["Title"] = "Search Results";
}

<div class="mt-4">

    <h2 class="mb-4">
        Search Results
    </h2>
    <p class="text-muted mb-1">
        Total results found:
        <strong>@ViewBag.ResultCount</strong>
        results for

    <strong>"@ViewBag.Query"</strong>
    </p>
    <div class="mb-3">

    <span class="badge bg-success fs-6 me-2">
        🏫 @ViewBag.CollegeCount Colleges
    </span>

    <span class="badge bg-primary fs-6 me-2">
        🎓 @ViewBag.SchoolCount Schools
    </span>

    <span class="badge bg-dark fs-6 me-2">
        📚 @ViewBag.CourseCount Courses
    </span>

    <span class="badge bg-danger fs-6">
        🔍 @ViewBag.ResultCount Total
    </span>

    </div>

    <hr />
    @if (ViewBag.Query != null)
    {
        <p class="text-muted mb-4">
            Showing results for:
            <strong>@ViewBag.Query</strong>
        </p>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            No results found.
        </div>
    }
    else
    {
        <div class="list-group">

            @foreach (var item in Model)
            {
                <a href="@item.Url"
                   class="list-group-item list-group-item-action mb-3 rounded shadow-sm">

                    <div class="d-flex justify-content-between align-items-center">

                        <h5 class="mb-1">
                            @item.Title
                        </h5>

                        @if (item.Type == "School")
                        {
                            <span class="badge bg-primary">
                                School
                            </span>
                        }
                        else if (item.Type == "College")
                        {
                            <span class="badge bg-success">
                                College
                            </span>
                        }
                        else if (item.Type == "Course")
                        {
                            <span class="badge bg-dark">
                                Course
                            </span>
                        }

                    </div>

                    @if (!string.IsNullOrEmpty(item.Description))
                    {
                        <div class="text-muted small">
                            @Html.Raw(item.Description)
                        </div>
                    }

                </a>
            }

        </div>

        @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">

                    @if (ViewBag.Page > 1)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               href="/search?q=@ViewBag.Query&page=@(ViewBag.Page - 1)">
                                Previous
                            </a>
                        </li>
                    }

                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                            <a class="page-link"
                               href="/search?q=@ViewBag.Query&page=@i">
                                @i
                            </a>
                        </li>
                    }

                    @if (ViewBag.Page < ViewBag.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               href="/search?q=@ViewBag.Query&page=@(ViewBag.Page + 1)">
                                Next
                            </a>
                        </li>
                    }

                </ul>
            </nav>
        }
    }

</div>
