@model SchoolProject.Models.Search.SearchResultViewModel

@{
    const string DefaultLogo = "/images/ui/default-logo.webp";
    const string DefaultCampus = "/images/ui/default-campus.webp";

    // Falls back when the DB value is NULL/empty.
    var campusImage = string.IsNullOrWhiteSpace(Model.CampusImage)
        ? DefaultCampus
        : Model.CampusImage;

    var logo = string.IsNullOrWhiteSpace(Model.Logo)
        ? DefaultLogo
        : Model.Logo;
}

<article class="be-card">

    <div class="be-campus-wrap">

        <img src="@campusImage"
             alt="@Model.Title"
             class="be-campus"
             loading="lazy"
             onerror="this.onerror=null;this.src='@DefaultCampus';" />

        @if (Model.Sponsored)
        {
            <div class="be-featured">

                ★ Featured

            </div>
        }

    </div>

    <div class="be-content">

        <div class="be-logo-column">

            <img src="@logo"
                 class="be-logo"
                 alt="@Model.Title Logo"
                 loading="lazy"
                 onerror="this.onerror=null;this.src='@DefaultLogo';" />

        </div>

        <div class="be-details">

            <h2>

                <a href="@Model.Url">

                    @Model.Title

                </a>

            </h2>

            @if (!string.IsNullOrWhiteSpace(Model.Address))
            {
                <div class="be-address">

                    📍 @Model.Address

                </div>
            }

            <div class="be-pill-row">

                @if (!string.IsNullOrWhiteSpace(Model.Ownership))
                {
                    <span class="be-pill">

                        🏛 @Model.Ownership

                    </span>
                }

                @if (Model.EstablishedYear.HasValue)
                {
                    <span class="be-pill">

                        📅 Since @Model.EstablishedYear

                    </span>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Accreditation))
                {
                    <span class="be-pill">

                        ⭐ @Model.Accreditation

                    </span>
                }

            </div>

            @if (Model.MatchingCourses.Any())
            {
                <div class="be-section-title">

                    Matches your search

                </div>

                <div class="be-chip-container">

                    @foreach (var course in Model.MatchingCourses.Take(6))
                    {
                        <a href="/search?q=@Uri.EscapeDataString(course)"
                           class="be-chip">

                            @course

                        </a>
                    }

                    @if (Model.MatchingCourses.Count > 6)
                    {
                        <span class="be-chip-more">

                            +@(Model.MatchingCourses.Count - 6) more

                        </span>
                    }

                </div>
            }

            <div class="be-description">

                @Html.Raw(Model.Description)

            </div>

            <div class="be-actions">

                <a href="@Model.Url"
                   class="be-btn be-btn-primary">

                    View College

                </a>

                <a href="@Model.Url#apply"
                   class="be-btn be-btn-secondary">

                    Apply Online

                </a>

            </div>

        </div>

    </div>

</article>